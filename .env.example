# Copy this file to .env and fill in your actual API keys
# NEVER commit the .env file to git

# Semantic Scholar API Key
# Request one at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_api_key_here

# Google Gemini API Keys (multiple keys for rate-limit rotation)
# Request at: https://aistudio.google.com/apikey
GEMINI_API_KEY1=your_api_key_here
GEMINI_API_KEY2=your_api_key_here
GEMINI_API_KEY3=your_api_key_here
GEMINI_API_KEY4=your_api_key_here
GEMINI_API_KEY5=your_api_key_here
GEMINI_API_KEY6=your_api_key_here
GEMINI_API_KEY7=your_api_key_here
GEMINI_API_KEY8=your_api_key_here
GEMINI_API_KEY9=your_api_key_here
GEMINI_API_KEY10=your_api_key_here

# Google Search API
GOOGLE_SEARCH_API_KEY=your_api_key_here
GOOGLE_SEARCH_CX=your_cx_here
